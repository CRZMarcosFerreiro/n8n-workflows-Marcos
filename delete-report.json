            "parameters": {
                "jsCode": "const items = $input.all();\nconst body = items[0].json.body || items[0].json;\nconst filename = body.filename;\nif (!filename) return [{ json: { success: false, error: 'Missing filename' } }];\nif (!/^[a-z0-9._-]+\\.html$/i.test(filename)) return [{ json: { success: false, error: 'Invalid filename' } }];\nif (filename.includes('..') || filename.includes('/') || filename.includes('\\\\')) return [{ json: { success: false, error: 'Path traversal not allowed' } }];\nif (filename === 'index.html') return [{ json: { success: false, error: 'Cannot delete index' } }];\nconst fs = require('fs');\nconst fpath = '/home/node/.n8n/informes/' + filename;\nif (!fs.existsSync(fpath)) return [{ json: { success: false, error: 'File not found' } }];\nfs.unlinkSync(fpath);\nreturn [{ json: { success: true, deleted: filename } }];"
            },
